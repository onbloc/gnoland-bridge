{
  "rewrites": [
    {
      "source": "/gno-rpc",
      "destination": "https://rpc.bridge.onbloc.xyz/"
    },
    {
      "source": "/gno-rpc/:path*",
      "destination": "https://rpc.bridge.onbloc.xyz/:path*"
    },
    {
      "source": "/relayer-api",
      "destination": "https://voyager-api.bridge.onbloc.xyz/"
    },
    {
      "source": "/relayer-api/:path*",
      "destination": "https://voyager-api.bridge.onbloc.xyz/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers" : [
        {
          "key" : "X-Content-Type-Options",
          "value" : "nosniff"
        },
        {
          "key" : "X-Frame-Options",
          "value" : "DENY"
        },
        {
          "key" : "X-XSS-Protection",
          "value" : "1; mode=block"
        }
      ]
    }
  ]
}
