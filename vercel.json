{
  "rewrites": [
    {
      "source": "/gno-rpc",
      "destination": "http://23.20.153.250:26657/"
    },
    {
      "source": "/gno-rpc/:path*",
      "destination": "http://23.20.153.250:26657/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers" : [
        {
          "key" : "X-Content-Type-Options",
          "value" : "nosniff"
        },
        {
          "key" : "X-Frame-Options",
          "value" : "DENY"
        },
        {
          "key" : "X-XSS-Protection",
          "value" : "1; mode=block"
        }
      ]
    }
  ]
}
